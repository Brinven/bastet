# Bastet — environment / secrets template
# Copy to .dev.vars for local Worker dev (wrangler reads .dev.vars automatically).
# In production these are set via `wrangler secret put <NAME>`.

# Resend API key — magic link email delivery (Tier 2 auth, M6+).
# Leave EMPTY in local dev: request-link then returns the sign-in link in its JSON response
# instead of sending email, so the whole auth flow is testable without a Resend account.
RESEND_API_KEY=

# From address for magic-link email. Must be a domain verified in Resend with SPF/DKIM
# (CLAUDE.md gotcha #11) or mail lands in spam. Format: "Bastet <bastet@axly.com>".
MAGIC_LINK_FROM=Bastet <bastet@axly.com>

# Admin bearer token — gates /api/admin/* template approval routes (M8)
ADMIN_BEARER_TOKEN=

# Base URL used to build magic links + the post-verify redirect, e.g. https://bastet.axly.com
# (local dev: http://localhost:5173). Falls back to the request origin if unset.
MAGIC_LINK_BASE_URL=

# Env marker. wrangler.toml sets this to "production"; set to "development" in .dev.vars so
# local session cookies are NOT marked Secure (they'd be dropped over plain http://localhost).
ENVIRONMENT=development
