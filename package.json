{
  "name": "bastet",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Free, open-source, browser-based flyer/poster maker for volunteer animal rescues.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "worker:dev": "wrangler dev --local --port 8787",
    "d1:migrate:local": "wrangler d1 migrations apply bastet-db --local",
    "d1:migrate:remote": "wrangler d1 migrations apply bastet-db --remote"
  },
  "dependencies": {
    "hono": "4.12.27",
    "jspdf": "4.2.1",
    "konva": "9.3.22",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-konva": "18.2.16"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260626.1",
    "@vitejs/plugin-react": "4.7.0",
    "autoprefixer": "10.5.2",
    "playwright": "1.61.1",
    "postcss": "8.5.15",
    "tailwindcss": "3.4.19",
    "vite": "5.4.21",
    "wrangler": "4.105.0"
  }
}
